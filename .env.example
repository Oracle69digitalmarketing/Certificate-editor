# Surgical PDF Engine Settings
PAPERLESS_TOKEN=your_generated_api_token_here

# Paperless-ngx Custom Field IDs (Map these to your instance IDs)
PAPERLESS_CUSTOM_FIELD_ID_CERT_NUMBER=1
PAPERLESS_CUSTOM_FIELD_ID_ISSUE_DATE=2
PAPERLESS_CUSTOM_FIELD_ID_RECIPIENT=3

# Paperless-ngx Security
PAPERLESS_SECRET_KEY=change-this-to-a-very-long-random-string
